variable "project_name" {
  description = "Name of the project"
  type        = string
  default     = "my-local-project"
}

variable "author" {
  description = "Author name"
  type        = string
  default     = "devops learner"
}

variable "environment" {
  description = "Environment name"
  type        = string
  default     = "development"
}